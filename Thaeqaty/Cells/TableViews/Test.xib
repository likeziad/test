<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24765" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24743"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>

    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>

        <tableViewCell contentMode="scaleToFill"
                       selectionStyle="default"
                       indentationWidth="10"
                       rowHeight="200"
                       id="cell">

            <rect key="frame" x="0" y="0" width="266" height="200"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>

            <tableViewCellContentView key="contentView"
                                      opaque="NO"
                                      clipsSubviews="YES"
                                      contentMode="center"
                                      tableViewCell="cell"
                                      id="contentView">

                <rect key="frame" x="0" y="0" width="266" height="200"/>

                <subviews>

                    <label opaque="NO" id="lblLike">
                        <rect key="frame" x="12" y="10" width="70" height="20"/>
                        <string key="text">أعجبني</string>
                        <color key="textColor" red="0.0" green="0.75" blue="0.75" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="12"/>
                    </label>

                    <label opaque="NO" id="lblDislike">
                        <rect key="frame" x="90" y="10" width="90" height="20"/>
                        <string key="text">لم يعجبني</string>
                        <color key="textColor" red="0.0" green="0.75" blue="0.75" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="12"/>
                    </label>

                    <label opaque="NO" id="lblDelay">
                        <rect key="frame" x="12" y="35" width="140" height="18"/>
                        <string key="text">تأخر علي عشر دقايق</string>
                        <color key="textColor" red="0.4" green="0.4" blue="0.4" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                    </label>

                    <label opaque="NO" id="lblDate">
                        <rect key="frame" x="160" y="35" width="90" height="18"/>
                        <string key="text">قبل يومين</string>
                        <color key="textColor" red="0.5" green="0.5" blue="0.5" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                    </label>

                    <label opaque="NO" id="lblRateFrom">
                        <rect key="frame" x="12" y="60" width="70" height="18"/>
                        <string key="text">تقييم من</string>
                        <color key="textColor" red="0.0" green="0.75" blue="0.75" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                    </label>

                    <label opaque="NO" id="lblName">
                        <rect key="frame" x="85" y="60" width="150" height="18"/>
                        <string key="text">جاسم حسين</string>
                        <color key="textColor" red="0.2" green="0.2" blue="0.2" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11" weight="medium"/>
                    </label>

                    <textField opaque="NO"
                               borderStyle="roundedRect"
                               placeholder="الرد على هذا التعليق"
                               id="txtReply">
                        <rect key="frame" x="12" y="90" width="200" height="34"/>
                        <color key="backgroundColor" red="0.95" green="0.95" blue="0.97" alpha="1" colorSpace="calibratedRGB"/>
                        <fontDescription key="fontDescription" type="system" pointSize="13"/>
                    </textField>

                    <button opaque="NO"
                            contentMode="scaleToFill"
                            id="btnSend">
                        <rect key="frame" x="218" y="90" width="36" height="34"/>
                        <color key="backgroundColor" red="1" green="0.55" blue="0.15" alpha="1" colorSpace="calibratedRGB"/>
                        <state key="normal" title="➤">
                            <color key="titleColor" white="1" alpha="1"/>
                        </state>
                    </button>

                </subviews>
            </tableViewCellContentView>

            <point key="canvasLocation" x="140" y="160"/>
        </tableViewCell>
    </objects>
</document>
